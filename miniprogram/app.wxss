@import "styles/tokens.wxss";
@import "styles/components.wxss";

/* 你原有的 app.wxss 内容保持不动... */

/* ── Global Styles for 小红花目标簿 ── */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background: #F7F0E8;
  color: #1E1210;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ── Section label ── */
.sec-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #C8B0A4;
  letter-spacing: 5rpx;
  margin-bottom: 28rpx;
}

/* ── Primary button ── */
.btn-p {
  background: linear-gradient(135deg, #D94F3D 0%, #E8784A 55%, #E8A84A 100%);
  color: white;
  border: none;
  border-radius: 100rpx;
  padding: 26rpx 68rpx;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 32rpx rgba(217, 79, 61, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  text-align: center;
}

.btn-p:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-p.w100 {
  width: 100%;
  box-sizing: border-box;
}

/* ── Ghost button ── */
.btn-ghost {
  background: transparent;
  color: #5C3A30;
  border: 1px solid rgba(180, 130, 110, 0.30);
  border-radius: 100rpx;
  padding: 22rpx 52rpx;
  font-size: 26rpx;
  font-weight: 400;
  letter-spacing: 0.6rpx;
  text-align: center;
}

.btn-ghost:active {
  border-color: #D94F3D;
  color: #D94F3D;
}

/* ── Card base ── */
.fcard {
  background: #FFFCF8;
  border-radius: 44rpx;
  border: 1px solid rgba(180, 130, 110, 0.13);
  padding: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(160, 90, 70, 0.07);
  margin-bottom: 28rpx;
}

/* ── Form elements ── */
.flabel {
  display: block;
  font-size: 22rpx;
  font-weight: 500;
  color: #A8897A;
  margin-bottom: 16rpx;
  letter-spacing: 3rpx;
}

.finput {
  width: 100%;
  background: #F7F0E8;
  border: 3rpx solid transparent;
  border-radius: 24rpx;
  padding: 26rpx 28rpx;
  font-size: 28rpx;
  font-weight: 400;
  color: #1E1210;
  box-sizing: border-box;
  min-height: 80rpx;
}

.finput-focus {
  border-color: #D94F3D;
  background: #FFFFFF;
  box-shadow: 0 0 0 6rpx rgba(217, 79, 61, 0.07);
}

.finput-placeholder {
  color: #C8B0A4;
}

/* ── Utility ── */
.tc {
  text-align: center;
}

.mt14 {
  margin-top: 28rpx;
}

.mt18 {
  margin-top: 36rpx;
}
