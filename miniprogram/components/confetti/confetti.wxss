.cf-stage {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 300;
  overflow: hidden;
}

.cp {
  position: absolute;
  top: -24rpx;
  animation: cfFall linear forwards;
}

@keyframes cfFall {
  0% {
    transform: translateY(-20rpx) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(105vh) rotate(720deg);
    opacity: 0;
  }
}
