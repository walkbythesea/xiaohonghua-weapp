.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(30, 18, 16, 0.60);
  z-index: 200;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.overlay.show {
  display: flex;
  animation: fadeBg 0.25s ease;
}

@keyframes fadeBg {
  from { opacity: 0; }
  to { opacity: 1; }
}

.praise-card {
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 68rpx 52rpx 56rpx;
  width: 100%;
  max-width: 680rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
  animation: popIn 0.38s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes popIn {
  from {
    transform: scale(0.78);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.praise-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(135deg, #D94F3D 0%, #E8784A 55%, #E8A84A 100%);
}

.praise-logo-wrap {
  width: 144rpx;
  height: 144rpx;
  background: #F7F0E8;
  border-radius: 40rpx;
  border: 1px solid rgba(180, 130, 110, 0.13);
  margin: 0 auto 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(160, 90, 70, 0.11);
  animation: spinPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.08s both;
}

@keyframes spinPop {
  from {
    transform: rotate(-15deg) scale(0);
    opacity: 0;
  }
  to {
    transform: rotate(0) scale(1);
    opacity: 1;
  }
}

.praise-logo {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
}

.praise-meta {
  font-size: 22rpx;
  font-weight: 300;
  color: #C8B0A4;
  margin-bottom: 24rpx;
  letter-spacing: 0.6rpx;
  display: block;
}

.praise-ttl {
  font-size: 48rpx;
  font-weight: 700;
  color: #D94F3D;
  margin-bottom: 24rpx;
  line-height: 1.3;
  display: block;
}

.praise-body {
  font-size: 28rpx;
  font-weight: 300;
  color: #5C3A30;
  line-height: 1.85;
  margin-bottom: 48rpx;
  padding: 0 8rpx;
  min-height: 100rpx;
  display: block;
}

.praise-body.loading {
  color: #C8B0A4;
  font-style: italic;
}

.praise-close {
  background: linear-gradient(135deg, #D94F3D 0%, #E8784A 55%, #E8A84A 100%);
  color: white;
  border-radius: 100rpx;
  padding: 24rpx 72rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 28rpx rgba(217, 79, 61, 0.26);
  display: inline-block;
  text-align: center;
}

.praise-close:active {
  opacity: 0.85;
  transform: scale(0.97);
}
